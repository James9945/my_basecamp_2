<h1>Admin Dashboard</h1>

<table class="table">
  <thead>
    <tr>
      <th>Email</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= user.has_role?(:admin) ? "Admin" : "User" %></td>
        <td>
          <% if user.has_role?(:admin) %>
            <%= link_to "Remove Admin", update_role_admin_dashboard_user_path(user, role: "remove_admin"), method: :patch, class: "btn btn-warning", data: { confirm: "Are you sure?" } %>
          <% else %>
            <%= link_to "Make Admin", update_role_admin_dashboard_user_path(user, role: "admin"), method: :patch, class: "btn btn-success" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
