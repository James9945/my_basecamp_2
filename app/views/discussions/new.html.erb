<h1>New Discussion</h1>

<%= form_with model: [@project, @discussion], local: true do |f| %>
  <div class="form-group">
    <%= f.label :title, "Discussion Title" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mt-3">
    <%= f.submit "Create Discussion", class: "btn btn-success" %>
  </div>
<% end %>

<%= link_to "Back to Project", project_path(@project), class: "btn btn-secondary mt-3" %>
