<div class="container text-center mt-5">
  <h1>Welcome to MyBaseCamp!</h1>
  </br>
  </br>
  <div>
    <% if user_signed_in? %>
      <%= link_to "Go to Projects", projects_path, class: "btn btn-primary" %>
    <% else %>
      <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-success mx-2" %>
      <%= link_to "Login", new_user_session_path, class: "btn btn-info mx-2" %>
    <% end %>
  </div>
</div>
