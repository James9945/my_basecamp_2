<%= form_with(model: @project, local: true, html: { multipart: true }) do |form| %>
  <div class="form-group">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :description %>
    <%= form.text_area :description, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :attachments, "Upload Attachments" %>
    <%= form.file_field :attachments, multiple: true, class: "form-control" %>
  </div>

  <%= form.submit "Save Project", class: "btn btn-primary" %>
<% end %>
